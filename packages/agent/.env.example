# Worker wallet private key (NEVER commit the real value)
WORKER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# Base RPC URL
BASE_RPC_URL=https://mainnet.base.org

# Treasury Manager contract address (deployed on Base)
TREASURY_MANAGER_ADDRESS=0x_TREASURY_MANAGER_ADDRESS_HERE

# Safety limits
MAX_SWAP_ETH=1.0
MIN_SLIPPAGE_BPS=10
POLL_INTERVAL_MS=5000

# Optional: Alchemy RPC (better rate limits)
# ALCHEMY_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
